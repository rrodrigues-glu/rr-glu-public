    {
      "severity": "MAJOR",
      "name": "1.2.4 Create 'access-list' for use with 'line vty'",
      "os": "ios",
      "source": "LATEST",
      "type": "SIMPLE",
      "description": "Access lists control the transmission of packets on an interface, control Virtual Terminal Line (VTY) access, and restrict the contents of routing updates. The Cisco IOS software stops checking the extended access list after a match occurs.",
      "scopeSeparateResults": true,
      "scope": "allow_ssh_in",
      "thenExpression": {
        "condition": "AND",
        "rules": [
          {
            "id": "latestConfig",
            "field": "latestConfig",
            "type": "string",
            "input": "textarea",
            "operator": "must_contain_regex",
            "value": [
              " permit tcp host \\S+ any eq 22",
              " deny   ip any any"
            ]
          }
        ],
        "valid": true
      },
      "conceptItem": "IOS_LineConVty",
      "enable": true,
      "commandSet": "all",
      "commandSetResult": {
        "type": "basicMode"
      }
    },
