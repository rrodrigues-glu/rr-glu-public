{
    "name": "Intf",
    "vendors": {
        "cisco": {
            "type": [
                "ios"
            ],
            "level": null,
            "note": null
        }
    },
    "showCmds": [
        "show ip vrf interfaces | exclude unassigned"
    ],
    "keyCliLine": ".+(up)",
    "rootEntryFlag": false,
    "mode": "basic",
    "boundaries": {
        "start": null
    },
    "discover": {
        "1": {
            "expressions": [
                "description (.+)"
            ]
        },
        "2": {
            "expressions": [
                "^shutdown$"
            ]
        },
        "3": {
            "expressions": [
                "(?<accessMode>^switchport mode access$)",
                "(?<trunkMode>^switchport mode trunk$)",
                "(?<trunkAllowed>^switchport trunk allowed vlan .+$)",
                "switchport access vlan (?<access>.+)",
                "switchport voice vlan (?<voice>.+)"
            ]
        },
        "5": {
            "expressions": [
                "ip flow monitor (?<input>.+) input$",
                "ip flow monitor (?<output>.+) output$"
            ]
        },
        "7": {
            "expressions": [
                "ip helper-address (?<ip>\\d*.\\d*.\\d*.\\d*)"
            ]
        }
    },
    "removeSyntax": {
        "no macro description.+": ""
    },
    "@exportedInstanceId": "736c9efa-1498-4fec-a0fa-fd5dd01dd53c",
    "@id": "736c9efa-1498-4fec-a0fa-fd5dd01dd53c",
    "@type": {
        "ref": "/sys/type/construct/global/conceptItem.jtype"
    },
    "@name": "IOS_Intf2-mrck2-DD",
    "@description": "Displays the running configuration starting from the first line that BEGINS with the word interface. Note: The ^ makes the parser ONLY display the section whose first line BEGINS with the word 'interface'. Note: This concept item DOES NOT display the hidden commands (unlike the IOS_Intf concept item)."
}