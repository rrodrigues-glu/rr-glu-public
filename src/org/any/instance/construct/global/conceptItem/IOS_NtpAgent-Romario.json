{
    "name": "NtpAgent",
    "vendors": {
        "cisco": {
            "type": [
                "ios"
            ],
            "level": null,
            "note": null
        }
    },
    "showCmds": [
        "sh run | sec ^ntp",
        "sh run | sec ^clock"
    ],
    "keyCliLine": "",
    "rootEntryFlag": true,
    "mode": "basic",
    "boundaries": {
        "start": null
    },
    "discover": {
        "timezone": {
            "expressions": [
                "clock timezone (.+)"
            ]
        },
        "intf": {
            "expressions": [
                "^interface\\s(?<Gi>.+)\\s.+description\\s(?<test>.+)$"
            ]
        }
    },
    "removeSyntax": {},
    "@exportedInstanceId": "5424a4e3-e79e-4c88-be06-cf791c4452d5",
    "@id": "5424a4e3-e79e-4c88-be06-cf791c4452d5",
    "@type": {
        "ref": "/sys/type/construct/global/conceptItem.jtype"
    },
    "@name": "IOS_NtpAgent-Romario",
    "@description": "Displays the sections that show the NTP and Clock configuration parameters. Note: The ^ makes the parser ONLY display the sections whose first lines BEGIN with 'ntp' or 'clock'."
}