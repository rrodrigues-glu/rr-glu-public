{
    "name": "NtpAgent",
    "vendors": {
        "cisco": {
            "type": [
                "ios"
            ],
            "level": null
        }
    },
    "showCmds": [
        "sh run | sec ^ntp"
    ],
    "keyCliLine": "",
    "rootEntryFlag": true,
    "mode": "basic",
    "boundaries": {
        "start": null
    },
    "discover": {
        "timezone": {
            "expressions": [
                "clock timezone (.+)"
            ]
        },
        "source": {
            "expressions": [
                "ntp source (.+)"
            ]
        }
    },
    "removeSyntax": {},
    "@id": "b8230b0b-8b36-42a3-ab27-a6ab40b9c7db",
    "@name": "IOS_NtpAgent-RRntp",
    "@description": "Displays the sections that show the NTP and Clock configuration parameters. Note: The ^ makes the parser ONLY display the sections whose first lines BEGIN with 'ntp' or 'clock'.",
    "@type": {
        "ref": "/sys/type/construct/global/conceptItem.jtype"
    }
}